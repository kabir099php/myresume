# Reverse-proxy config for the single Node server.
# Copy to /etc/nginx/sites-available/kabir-portfolio, symlink into sites-enabled,
# replace your-domain.com, then: sudo nginx -t && sudo systemctl reload nginx
# Add HTTPS automatically with: sudo certbot --nginx -d your-domain.com -d www.your-domain.com

server {
    listen 80;
    server_name your-domain.com www.your-domain.com;

    location / {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
